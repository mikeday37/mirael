                        "name": "distance",
                        "outputs": "out",
                        "script": "output[1]=function(image,c)\n\tc=c+100000\n  local w,h = image.w,image.h\n  local ws,cdiv=300,150\n  local cx,cy =\n    w/2+ws*math.cos(c/cdiv),\n    h/2+ws*math.sin(c/cdiv)\n  for x=0,w-1 do\n    for y=0,h-1 do\n      local dx,dy=cx-x,cy-y\n      local d = math.sqrt(dx*dx+dy*dy)/1.5 % 255\n      putpixel(image,x,y,255-d/0.2+y*3,d-x+math.sqrt(y)*(y+x/3+c/2.2),55-d,255-d)\n    end\n  end\nend"
