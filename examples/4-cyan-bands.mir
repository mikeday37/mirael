                        "script": "output[1]=function(image,c)\n  local w,h = image.w,image.h\n  local ws,cdiv=1,400\n  local cx,cy = w/.3+ws*math.cos(c/cdiv),h/2+ws*math.sin(c/cdiv)\n  for x=0,w-1 do\n    for y=0,h-1 do\n      local dx,dy=cx-x,cy-y\n      local d = ((dx*dx+dy*dy/dx+x*y*y/500)/1.5) % 255\n      putpixel(image,x,y,255-d,(d+64)%255,d)\n    end\n  end\nend"
